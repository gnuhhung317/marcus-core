{
  "info": {
    "_postman_id": "7f2272ae-4448-4d6c-b6a3-4d9f1f65e8d8",
    "name": "Marcus Trading API",
    "description": "Collection generated from Marcus backend controllers. Import the environment first, log in once, and the access token will be saved into {{jwt}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register user",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"demo.trader\",\"displayName\":\"Demo Trader\",\"password\":\"Password123!\",\"email\":\"demo.trader@example.com\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\":\"demo.trader\",\"password\":\"Password123!\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const response = pm.response.json();",
                  "  if (response.accessToken) { pm.environment.set('jwt', response.accessToken); }",
                  "  if (response.refreshToken) { pm.environment.set('refreshToken', response.refreshToken); }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh token",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"refreshToken\":\"{{refreshToken}}\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get overview",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/overview"
          }
        },
        {
          "name": "Get equity series",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/dashboard/equity-series?range=30d"
